# .env.example
# MongoDB connection string
DATABASE_URL="mongodb+srv://<username>:<password>@<host>/<database>?retryWrites=true&w=majority&appName=<appName>&maxPoolSize=30&minPoolSize=5&waitQueueTimeoutMS=10000&serverSelectionTimeoutMS=5000"

# JWT secret key
JWT_SECRET=<your_jwt_secret>

# Email configuration
EMAIL_USER=<your_email>
EMAIL_PASSWORD=<your_email_password>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Cloudinary configuration
CLOUDINARY_NAME=<your_cloudinary_name>
CLOUDINARY_KEY=<your_cloudinary_key>
CLOUDINARY_SECRET=<your_cloudinary_secret>

# Server port
PORT=3001

# Cookie configuration
MAX_AGE_COOKIES = 86400000 //1 day in milliseconds

# Node environment
NODE_ENV=development

# Redis configuration (BullMQ)
# Se estiver local:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=undefined

# Rate limit (Redis)
RATE_LIMIT_ENABLED=true
